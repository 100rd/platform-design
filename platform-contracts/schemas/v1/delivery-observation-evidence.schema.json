{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:darkfactory:platform-contract:delivery-observation-evidence:v1",
  "title": "DeliveryObservationEvidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workOrderId",
    "identityBindingDigest",
    "adapterBindingDigest",
    "scopeDigest",
    "semanticVerifier",
    "applicationUid",
    "applicationGeneration",
    "namespaceUid",
    "mergeCommitSha",
    "imageDigest",
    "renderedInventoryDigest",
    "repositoryAuthorizationDigest",
    "controlInventoryDigest",
    "controlObjectDigests",
    "admissionRbacDigest",
    "inheritedAuthorityDigest",
    "transportRecordingDigest",
    "totalObjectCount",
    "finalCollectionSnapshots",
    "canonicalization",
    "digestPayloadExcludes",
    "evidenceSha256",
    "observedAt",
    "expiresAt",
    "verifier"
  ],
  "properties": {
    "schemaVersion": {"const": "delivery/observation-evidence/v1"},
    "workOrderId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{7,52}$"},
    "identityBindingDigest": {"$ref": "#/$defs/digest"},
    "adapterBindingDigest": {"$ref": "#/$defs/digest"},
    "scopeDigest": {"$ref": "#/$defs/digest"},
    "semanticVerifier": {"const": "realm.preview-delivery-observed/v1"},
    "applicationUid": {"type": "string", "minLength": 1, "maxLength": 128},
    "applicationGeneration": {"type": "integer", "minimum": 1},
    "namespaceUid": {"type": "string", "minLength": 1, "maxLength": 128},
    "mergeCommitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "imageDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "renderedInventoryDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "repositoryAuthorizationDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "controlInventoryDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "controlObjectDigests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicationRole",
        "applicationRoleBinding",
        "inventoryClusterRole",
        "namespaceClusterRole",
        "namespaceClusterRoleBinding",
        "realmRoleBinding",
        "serviceAccount"
      ],
      "properties": {
        "applicationRole": {"$ref": "#/$defs/digest"},
        "applicationRoleBinding": {"$ref": "#/$defs/digest"},
        "inventoryClusterRole": {"$ref": "#/$defs/digest"},
        "namespaceClusterRole": {"$ref": "#/$defs/digest"},
        "namespaceClusterRoleBinding": {"$ref": "#/$defs/digest"},
        "realmRoleBinding": {"$ref": "#/$defs/digest"},
        "serviceAccount": {"$ref": "#/$defs/digest"}
      }
    },
    "admissionRbacDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "inheritedAuthorityDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "transportRecordingDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "totalObjectCount": {"type": "integer", "minimum": 0, "maximum": 100},
    "finalCollectionSnapshots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apps-v1-deployments",
        "apps-v1-replicasets",
        "discovery-v1-endpointslices",
        "networking-v1-ingresses",
        "networking-v1-networkpolicies",
        "rbac-v1-rolebindings",
        "rbac-v1-roles",
        "v1-persistentvolumeclaims",
        "v1-pods",
        "v1-resourcequotas",
        "v1-serviceaccounts",
        "v1-services"
      ],
      "properties": {
        "apps-v1-deployments": {"$ref": "#/$defs/appsDeployment"},
        "apps-v1-replicasets": {"$ref": "#/$defs/appsReplicaSet"},
        "discovery-v1-endpointslices": {"$ref": "#/$defs/discoveryEndpointSlice"},
        "networking-v1-ingresses": {"$ref": "#/$defs/networkingIngress"},
        "networking-v1-networkpolicies": {"$ref": "#/$defs/networkingNetworkPolicy"},
        "rbac-v1-rolebindings": {"$ref": "#/$defs/rbacRoleBinding"},
        "rbac-v1-roles": {"$ref": "#/$defs/rbacRole"},
        "v1-persistentvolumeclaims": {"$ref": "#/$defs/corePersistentVolumeClaim"},
        "v1-pods": {"$ref": "#/$defs/corePod"},
        "v1-resourcequotas": {"$ref": "#/$defs/coreResourceQuota"},
        "v1-serviceaccounts": {"$ref": "#/$defs/coreServiceAccount"},
        "v1-services": {"$ref": "#/$defs/coreService"}
      }
    },
    "canonicalization": {"const": "rfc8785-json-canonicalization/v1"},
    "digestPayloadExcludes": {"const": ["evidenceSha256", "verifier.signature"]},
    "evidenceSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "observedAt": {"type": "string", "format": "date-time"},
    "expiresAt": {"type": "string", "format": "date-time"},
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileDigest", "subject", "signingKeyId", "algorithm", "signature"],
      "properties": {
        "profileDigest": {"$ref": "#/$defs/digest"},
        "subject": {"type": "string", "minLength": 1, "maxLength": 253},
        "signingKeyId": {"type": "string", "minLength": 1, "maxLength": 253},
        "algorithm": {"enum": ["ECDSA_SHA_256", "Ed25519"]},
        "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{43,4096}$"}
      }
    }
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "appsDeployment": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "apps/v1/Deployment"}}},
    "appsReplicaSet": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "apps/v1/ReplicaSet"}}},
    "discoveryEndpointSlice": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "discovery.k8s.io/v1/EndpointSlice"}}},
    "networkingIngress": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "networking.k8s.io/v1/Ingress"}}},
    "networkingNetworkPolicy": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "networking.k8s.io/v1/NetworkPolicy"}}},
    "rbacRoleBinding": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "rbac.authorization.k8s.io/v1/RoleBinding"}}},
    "rbacRole": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "rbac.authorization.k8s.io/v1/Role"}}},
    "corePersistentVolumeClaim": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "v1/PersistentVolumeClaim"}}},
    "corePod": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "v1/Pod"}}},
    "coreResourceQuota": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "v1/ResourceQuota"}}},
    "coreServiceAccount": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "v1/ServiceAccount"}}},
    "coreService": {"$ref": "urn:darkfactory:platform-contract:namespaced-resource-snapshot:v1", "properties": {"kindId": {"const": "v1/Service"}}}
  }
}
