      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "AKS + InfiniBand GPU fabric \u00b7 Entra Workload Identity \u00b7 Azure CNI Powered by Cilium. Two regional clusters joined east-west via Azure Kubernetes Fleet Manager (managed Cilium Cluster Mesh) over Global VNet peering. Networking fabric highlighted. CI/CD pipelines on the left.",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "containerId": null,
      "originalText": "AKS + InfiniBand GPU fabric \u00b7 Entra Workload Identity \u00b7 Azure CNI Powered by Cilium. Two regional clusters joined east-west via Azure Kubernetes Fleet Manager (managed Cilium Cluster Mesh) over Global VNet peering. Networking fabric highlighted. CI/CD pipelines on the left.",
      "lineHeight": 1.25,
      "autoResize": true
    },
