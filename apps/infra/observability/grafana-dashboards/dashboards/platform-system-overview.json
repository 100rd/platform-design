    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Cost allocation placeholder — requires OpenCost (ADR-0027) to be deployed.\nOnce OpenCost is available, replace the expr below with:\n  sum(opencost_namespace_hourly_cost_dollars{namespace=~\"$system.*\"}) by (namespace)\nor the equivalent system-label query against the OpenCost Prometheus exporter.\n\nThis panel is intentionally left as a placeholder so the $system template\nvariable and row are established in the dashboard — teams add real PromQL\nwhen OpenCost is integrated per ADR-0027.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "light-blue"},
          "custom": {
            "axisCenteredZero": false,
