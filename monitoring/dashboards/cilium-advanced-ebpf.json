      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "min(cilium_feature_status{name='sockops'})",
          "legendFormat": "Sockops",
          "refId": "A"
        }
      ],
      "title": "Socket-Level LB (sockops)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short"
        },
        "overrides": []
